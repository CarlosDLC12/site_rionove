rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra Global: Apenas Administradores (vias Admin SDK no servidor) 
    // podem escrever, deletar ou atualizar dados.
    match /{document=**} {
      allow write, update, delete: if false; 
    }

    // Regras Específicas: Leitura
    // Qualquer pessoa pode ler a lista de produtos (para a vitrine funcionar)
    match /products/{productId} {
      allow read: if true;
    }
    
    // Ninguém pode ler a coleção de vendas pelo frontend
    // O Webhook salva os dados via Admin SDK que ignora essas regras.
    match /sales/{saleId} {
      allow read: if false;
    }
  }
}
